{
  "name": "site-creator-vinext-starter",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "build:gcloud": "CLOUD_RUN_BUILD=1 next build --webpack",
    "start:gcloud": "node .next/standalone/server.js",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate",
    "db:schema": "node --env-file=.env.local scripts/apply_supabase_schema.mjs",
    "db:seed": "node --env-file=.env.local scripts/sync_schools_to_supabase.mjs",
    "db:seed-auth": "node --env-file=.env.local --env-file=.env.seed.local scripts/seed_auth_users.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.7",
    "drizzle-orm": "0.45.2",
    "google-auth-library": "^10.9.0",
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "pdf-lib": "^1.17.1",
    "pg": "^8.16.3",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
