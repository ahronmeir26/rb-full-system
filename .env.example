SUPABASE_URL=
SUPABASE_SECRET_KEY=
DATABASE_URL=
# Optional dedicated HMAC key for signed school upload links. When omitted,
# the server-only Supabase secret key is used.
SCHOOL_UPLOAD_LINK_SECRET=

# Google Cloud OAuth web client with the Gmail API enabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_REDIRECT_URI=
# A long random value used only to encrypt the stored Gmail refresh token.
GMAIL_TOKEN_ENCRYPTION_KEY=
# Cloud Run service URL and the scheduler service account allowed to trigger
# the protected all-mailbox synchronization endpoint.
CLOUD_RUN_SERVICE_URL=
GMAIL_SYNC_SERVICE_ACCOUNT=

# Klaviyo private API key with only the events:write scope. Outgoing compose
# actions create this metric; a live metric-triggered Klaviyo flow sends it.
KLAVIYO_PRIVATE_API_KEY=
KLAVIYO_OUTGOING_EMAIL_METRIC=Appreciation Initiative Outgoing Email
KLAVIYO_API_REVISION=2026-07-15

# Create/install a Dev Dashboard app in the same Shopify organization as the
# store. Use the permanent *.myshopify.com domain and keep the secret server-side.
SHOPIFY_STORE_DOMAIN=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_API_VERSION=2026-07

# Set after deploying shopify/extensions/appreciation-product-discounts.
SHOPIFY_DISCOUNT_FUNCTION_ID=
