SUPABASE_URL=
SUPABASE_SECRET_KEY=
DATABASE_URL=

# Google Cloud OAuth web client with the Gmail API enabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_REDIRECT_URI=
# A long random value used only to encrypt the stored Gmail refresh token.
GMAIL_TOKEN_ENCRYPTION_KEY=

# Create/install a Dev Dashboard app in the same Shopify organization as the
# store. Use the permanent *.myshopify.com domain and keep the secret server-side.
SHOPIFY_STORE_DOMAIN=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_API_VERSION=2026-07

# Set after deploying shopify/extensions/appreciation-product-discounts.
SHOPIFY_DISCOUNT_FUNCTION_ID=
